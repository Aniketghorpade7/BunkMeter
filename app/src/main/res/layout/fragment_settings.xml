<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"> <ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/idCardImage"
                    android:layout_width="200dp"
                    android:layout_height="260dp"
                    android:layout_gravity="center"
                    android:scaleType="centerCrop"
                    android:background="@drawable/card_bg"
                    android:src="@drawable/ic_id_card_placeholder"/>

                <TextView
                    android:id="@+id/tvStudentName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="12dp"
                    android:text="Student Name"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Roll Number"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/> <TextView
                android:id="@+id/tvPRN"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnSurface"
                android:text="0000001"
                android:textSize="16sp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Department"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/> <TextView
                android:id="@+id/tvDept"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnSurface"
                android:text="IT"
                android:textSize="16sp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Semester"
                    android:textSize="12sp"
                    android:textColor="?attr/colorOnSurfaceVariant"/> <TextView
                android:id="@+id/tvSem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/colorOnSurface"
                android:text="0"
                android:textSize="16sp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="20dp"
                    android:background="?attr/colorOutlineVariant"/> <LinearLayout
                android:id="@+id/cardProfile"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:gravity="center_vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="?attr/colorOnSurface"
                    android:text="Edit Profile"
                    android:textSize="16sp"/>

                <TextView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:text=">"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:gravity="center"/>
            </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardTimetable"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:gravity="center_vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="?attr/colorOnSurface"
                        android:text="Timetable"
                        android:textSize="16sp"/>

                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:text=">"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:gravity="center"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardClassroom"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:gravity="center_vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="?attr/colorOnSurface"
                        android:text="Classrooms"
                        android:textSize="16sp"/>

                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:text=">"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:gravity="center"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardExport"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:gravity="center_vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="?attr/colorOnSurface"
                        android:text="Export Data"
                        android:textSize="16sp"/>

                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:text=">"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:gravity="center"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardReset"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:gravity="center_vertical"
                    android:padding="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Reset App"
                        android:textColor="?attr/colorError" android:textSize="16sp"/>

                    <TextView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:text="!"
                        android:textColor="?attr/colorError"
                        android:gravity="center"/>
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>

</FrameLayout>